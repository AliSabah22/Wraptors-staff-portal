{
  "name": "wraptors-staff-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next node_modules/.cache",
    "dev": "next dev",
    "dev:clean": "npm run clean && next dev",
    "dev:safe": "npm run clean && node scripts/ensure-manifests.js && next build && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:types": "supabase gen types typescript --local > src/types/database.ts",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:studio": "supabase studio",
    "predev": "node -e \"try { require.resolve('next'); } catch(e) { console.error('Run yarn or npm install first'); process.exit(1); }\"",
    "db:seed": "supabase db seed",
    "setup:test-user": "tsx scripts/create-test-user.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
