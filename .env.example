# =============================================================================
# WRAPTORS STAFF PORTAL — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to the repository
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE
# Get these from: https://supabase.com/dashboard → your project → Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# WARNING: SUPABASE_SERVICE_ROLE_KEY bypasses RLS — only use in server-side API routes

# -----------------------------------------------------------------------------
# ANTHROPIC / OPENAI
# Intelligence module (CEO only) — AI-powered analytics and campaign generation
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# -----------------------------------------------------------------------------
# APP URL
# Development: http://localhost:3000
# Production: your Vercel deployment URL (e.g. https://portal.wraptors.com)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# SENDGRID (V2 — not required for launch)
# -----------------------------------------------------------------------------
# SENDGRID_API_KEY=your_sendgrid_api_key
# SENDGRID_FROM_EMAIL=noreply@wraptors.com
# SENDGRID_FROM_NAME=Wraptors

# -----------------------------------------------------------------------------
# TWILIO (V2 — not required for launch)
# -----------------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=your_twilio_phone_number

# -----------------------------------------------------------------------------
# META BUSINESS API (V2 — not required for launch)
# -----------------------------------------------------------------------------
# META_APP_ID=your_meta_app_id
# META_APP_SECRET=your_meta_app_secret
# META_LEADADS_WEBHOOK_VERIFY_TOKEN=your_custom_verify_token

# -----------------------------------------------------------------------------
# GOOGLE OAUTH (V2 — not required for launch)
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# -----------------------------------------------------------------------------
# SENTRY — Error Logging (V2 — not required for launch)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
# SENTRY_AUTH_TOKEN=your_sentry_auth_token
