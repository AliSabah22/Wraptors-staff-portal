# Wraptors Staff Portal — example environment variables
# Copy to .env.local and fill in values when adding a backend or integrations.
# The app currently runs with mock data and does not require any of these.

# Optional: API base URL when you add a backend
# NEXT_PUBLIC_API_URL=http://localhost:3001

# Intelligence (CEO only): Anthropic Claude API key for conversational analytics
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: integration keys (never commit .env to version control)
# META_APP_ID=
# META_APP_SECRET=
# META_LEADADS_WEBHOOK_VERIFY_TOKEN=
# SHOPIFY_SHOP=
# SHOPIFY_ACCESS_TOKEN=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=

# Optional: database (when moving off mock data)
# DATABASE_URL=postgresql://user:pass@localhost:5432/wraptors
